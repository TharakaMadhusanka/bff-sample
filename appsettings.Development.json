{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "angularFallbackRoute": {
        "ClusterId": "angularCluster",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "angularCluster": {
        "Destinations": {
          "angularDevServer": {
            "Address": "http://localhost:4200"
          }
        }
      }
    }
  }
}
